{
  "$schema": "https://ui.elorm.xyz/schema/elorm.json",
  "style": "elorm",
  "uiLibrary": "base-ui",
  "rsc": true,
  "tsx": true,
  "tailwind": {
    "css": "app/globals.css",
    "baseColor": "neutral",
    "cssVariables": true
  },
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/ui",
    "lib": "@/lib",
    "hooks": "@/hooks"
  },
  "iconLibrary": "lucide",
  "registries": {
    "@elorm": "https://ui.elorm.xyz/r/{library}/{name}.json"
  },
  "framework": "next",
  "theme": {
    "accent": "default",
    "radius": "0.5"
  }
}
